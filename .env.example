# ============================================================
# AI Agent 学习项目 - 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 在 .env 中填入你真实的 API Key
#   3. .env 文件已被 .gitignore 忽略，不会被提交到 Git
# ============================================================

# ----- DeepSeek（推荐主力模型，性价比高） -----
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ----- 通义千问 Qwen（阿里云） -----
# 申请地址：https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-key-here

# ----- 智谱 GLM -----
# 申请地址：https://open.bigmodel.cn/
GLM_API_KEY=your-glm-key-here

# ----- 方舟-----
# 申请地址：https://platform.moonshot.cn/
ARK_API_KEY=ark-your-volcengine-ark-key-here

# ----- Kimi / Moonshot -----
# 申请地址：https://platform.moonshot.cn/
KIMI_API_KEY=sk-your-kimi-key-here

# ----- Google Gemini -----
# 申请地址：https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
